# Example env file for local development
# Copy this to `.env` and paste your real keys. Keep values empty until you paste them.

# AI provider keys
VITE_GROQ_API_KEY=
VITE_GEMINI_API_KEY=

# Firebase required keys (paste your Firebase project values here)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: other VITE_ keys (if used)
# VITE_OTHER_KEY=
